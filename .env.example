########################################
# 星露谷物语服务器一键搭建配置
########################################

# JunimoServer 当前 sidecar 镜像没有 latest 标签，默认使用 preview。
# 需要固定版本时可改为类似 1.5.0-preview.54。
IMAGE_NAMESPACE=sdvd
IMAGE_VERSION=preview

########################################
# Docker 镜像拉取网络兜底
########################################

# Docker 拉取超时时间。公网服务器默认 300 秒，避免 Docker Hub 卡住太久。
# 设为 0 表示不额外限制。
DOCKER_PULL_TIMEOUT_SECONDS=300

# 可选：Docker Hub 镜像加速地址，多个地址用英文逗号、分号或空格分隔。
# 仅 Linux 脚本使用。留空时，交互式 setup 会在 Docker Hub 失败后现场询问。
DOCKER_REGISTRY_MIRRORS=""

# 非交互预授权开关：true 时，Linux 脚本在 Docker Hub 拉取失败后，可直接临时写入
# /etc/docker/daemon.json 并重启 Docker；false 时，交互式 setup 会先询问用户。
# 拉取结束后脚本会恢复原配置并再次重启 Docker。
# 注意：重启 Docker 会短暂影响同机其他 Docker 服务。
DOCKER_TEMP_MIRROR_RESTART_DOCKER=false

########################################
# Steam 登录/下载网络代理，可选
########################################

# 这组配置只用于 SteamClient / SteamCMD 登录和下载链路。
# 它不会解决 Docker Hub 拉镜像问题；Docker 拉镜像请使用上面的镜像源配置。
# 如果代理地址包含账号密码，请只写在本机 .env，不要提交到仓库或截图。
HTTP_PROXY=""
HTTPS_PROXY=""
ALL_PROXY=""
NO_PROXY="localhost,127.0.0.1,steam-auth,server"

# Steam Directory API 预检重试次数。阿里云等网络可能偶发超时，默认重试 3 次。
STEAM_NETWORK_CHECK_RETRIES=3

########################################
# 必填：Steam 账号
########################################

# 账号必须拥有 Stardew Valley。本项目不会分发游戏文件。
STEAM_USERNAME=""
STEAM_PASSWORD=""

########################################
# 管理入口
########################################

# Web VNC 管理密码。首次运行 setup 脚本会自动生成。
VNC_PASSWORD=""

# HTTP API 密钥。首次运行 setup 脚本会自动生成。
API_KEY=""
API_ENABLED=true

# Web 管理面板令牌。首次运行 setup/admin 脚本会自动生成。
# 服务器部署建议使用 ./scripts/sdv-server.sh admin-service-install 常驻运行，
# 然后在 1Panel 中把域名反向代理到 http://127.0.0.1:8088。
ADMIN_TOKEN=""
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8088
# 安全默认：管理面板只建议监听 127.0.0.1，再通过 HTTPS 反向代理访问。
# 如确需在可信内网直接监听 0.0.0.0，必须显式开启下面这一项。
ADMIN_ALLOW_PUBLIC_HTTP=false

########################################
# 端口
########################################

GAME_PORT=24642
QUERY_PORT=27015
VNC_PORT=5800
API_PORT=8080

# Web noVNC 虚拟显示器尺寸。大屏可改成 1920x1080。
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=800
XVNC_SERVER_CUSTOM_PARAMS="-AcceptPointerEvents=1 -AcceptKeyEvents=1 -AcceptSetDesktopSize=1 -AlwaysShared=1 -DisconnectClients=0"

########################################
# 游戏和安全
########################################

DISABLE_RENDERING=false

# 玩家进服后可通过 !login <password> 登录。留空表示不启用。
SERVER_PASSWORD=""
MAX_LOGIN_ATTEMPTS=3
AUTH_TIMEOUT_SECONDS=120

HEALTH_CHECK_SECONDS=300
ENABLE_MOD_INCOMPATIBLE_OPTIMIZATIONS=true
FORCE_NEW_DEBUG_GAME=false
VERBOSE_LOGGING=false

# Nexus Mods API Key，可选。SMAPI 搜索和 URL 安装不需要它；
# 配置后，Web 管理面板可读取 Nexus 文件列表和下载链接。
NEXUS_API_KEY=""

########################################
# 存档备份
########################################

# 游戏会自动写入 saves volume；这里控制 Web 管理面板是否定时导出备份包。
AUTO_BACKUP_ENABLED=false
SAVE_BACKUP_INTERVAL_MINUTES=360
SAVE_BACKUP_RETENTION=10

########################################
# Discord Bot，可选
########################################

# 开启方式：
#   docker compose --profile discord up -d
# 或 Windows：
#   .\setup.ps1 start -EnableDiscord
DISCORD_BOT_TOKEN=""
DISCORD_BOT_NICKNAME=""
DISCORD_CHAT_CHANNEL_ID=""
DISCORD_UPDATE_INTERVAL_MS=30000

########################################
# 高级：已有 Steam refresh token 时可填写
########################################

STEAM_REFRESH_TOKEN=""
