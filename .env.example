########################################
# 星露谷物语服务器一键搭建配置
########################################

# JunimoServer 当前 sidecar 镜像没有 latest 标签，默认使用 preview。
# 需要固定版本时可改为类似 1.5.0-preview.54。
IMAGE_VERSION=preview

########################################
# 必填：Steam 账号
########################################

# 账号必须拥有 Stardew Valley。本项目不会分发游戏文件。
STEAM_USERNAME=""
STEAM_PASSWORD=""

########################################
# 管理入口
########################################

# Web VNC 管理密码。首次运行 setup 脚本会自动生成。
VNC_PASSWORD=""

# HTTP API 密钥。首次运行 setup 脚本会自动生成。
API_KEY=""
API_ENABLED=true

# 本地 Web 管理面板令牌。首次运行 setup/admin 脚本会自动生成。
ADMIN_TOKEN=""
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8088

########################################
# 端口
########################################

GAME_PORT=24642
QUERY_PORT=27015
VNC_PORT=5800
API_PORT=8080

# Web noVNC 虚拟显示器尺寸。大屏可改成 1920x1080。
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=800
XVNC_SERVER_CUSTOM_PARAMS="-AcceptPointerEvents=1 -AcceptKeyEvents=1 -AcceptSetDesktopSize=1 -AlwaysShared=1 -DisconnectClients=0"

########################################
# 游戏和安全
########################################

DISABLE_RENDERING=false

# 玩家进服后可通过 !login <password> 登录。留空表示不启用。
SERVER_PASSWORD=""
MAX_LOGIN_ATTEMPTS=3
AUTH_TIMEOUT_SECONDS=120

HEALTH_CHECK_SECONDS=300
ENABLE_MOD_INCOMPATIBLE_OPTIMIZATIONS=true
FORCE_NEW_DEBUG_GAME=false
VERBOSE_LOGGING=false

########################################
# Discord Bot，可选
########################################

# 开启方式：
#   docker compose --profile discord up -d
# 或 Windows：
#   .\setup.ps1 start -EnableDiscord
DISCORD_BOT_TOKEN=""
DISCORD_BOT_NICKNAME=""
DISCORD_CHAT_CHANNEL_ID=""
DISCORD_UPDATE_INTERVAL_MS=30000

########################################
# 高级：已有 Steam refresh token 时可填写
########################################

STEAM_REFRESH_TOKEN=""
